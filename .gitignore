# Weights and models - ignored by extension (small bundled model weights are
# re-included individually below).
*.safetensors
*.gguf
*.bin
*.pt
*.pth
# Bundled model weights (small, ship with the package, package/weights/ layout).
!LTX_2_MLX/videotoolbox/fastdvdnet/weights/*.safetensors
!LTX_2_MLX/videotoolbox/basicvsrpp/weights/*.safetensors
# ntire_vsr (c128n25) exceeds GitHub's 100MB file limit, so it ships split into
# basicvsrpp_ntire_vsr.shardNN.safetensors (committed above) + a merging loader.
# Keep the reassembled full file out of git.
LTX_2_MLX/videotoolbox/basicvsrpp/weights/basicvsrpp_ntire_vsr.safetensors
*.ckpt

# Output files
*.mp4
*.npz
*.png
output/
gens/
outputs/

# Allow example files
!examples/*.mp4
!examples/*.png

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Test outputs
tests/outputs/
tests/fixtures/

# LTX-2 submodule (if cloned separately)
LTX-2/

# OBJECTIVE.md (generated during debugging)
OBJECTIVE.md

# Claude Code session state
.claude/
